# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development

# ─── PostgreSQL ────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=eg_sim_platform
DB_USER=eg_sim_user
DB_PASSWORD=changeme_strong_password

# ─── JWT ───────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_min_32_chars_long
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=changeme_refresh_secret_min_32_chars
JWT_REFRESH_EXPIRES_IN=30d

# ─── Docker (Simulation Engine) ────────────────────────────
DOCKER_SOCKET=/var/run/docker.sock
LAB_CONTAINER_TIMEOUT_MINUTES=60
LAB_MAX_CONTAINERS_PER_USER=2
LAB_IMAGE_LINUX=eg-sim-linux-lab:latest
LAB_IMAGE_WINDOWS_SIM=eg-sim-windows-sim:latest

# ─── Flag Engine ───────────────────────────────────────────
FLAG_SECRET=changeme_flag_hmac_secret_min_32_chars
FLAG_PREFIX=eGSIM

# ─── Frontend ──────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ─── Logging ───────────────────────────────────────────────
LOG_LEVEL=debug
