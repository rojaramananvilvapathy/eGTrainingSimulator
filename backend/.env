# ─── Server ───────────────────────────────────────────────
PORT=4000
NODE_ENV=development
	
# ─── PostgreSQL ────────────────────────────────────────────
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=eg_sim_db
DB_USER=eg_sim_user
